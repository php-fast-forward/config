{
    "name": "fast-forward/config",
    "description": "Fast Forward Config utility classes",
    "license": "MIT",
    "type": "library",
    "authors": [
        {
            "name": "Felipe Sayão Lobato Abreu",
            "email": "github@mentordosnerds.com"
        }
    ],
    "homepage": "https://php-fast-forward.github.io/config/",
    "support": {
        "issues": "https://github.com/php-fast-forward/config/issues",
        "source": "https://github.com/php-fast-forward/config"
    },
    "require": {
        "php": "^8.3",
        "dflydev/dot-access-data": "^3.0",
        "laminas/laminas-config-aggregator": "^1.13",
        "psr/container": "^1.0 || ^2.0",
        "psr/simple-cache": "^3.0"
    },
    "require-dev": {
        "fast-forward/dev-tools": "dev-main"
    },
    "minimum-stability": "stable",
    "autoload": {
        "psr-4": {
            "FastForward\\Config\\": "src/"
        },
        "files": [
            "src/functions.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "FastForward\\Config\\Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "ergebnis/composer-normalize": true,
            "fast-forward/dev-tools": true,
            "phpdocumentor/shim": true,
            "phpro/grumphp": true,
            "pyrech/composer-changelogs": true
        },
        "platform": {
            "php": "8.3.0"
        },
        "sort-packages": true
    },
    "extra": {
        "branch-alias": {
            "dev-main": "1.x-dev"
        },
        "grumphp": {
            "config-default-path": "vendor/fast-forward/dev-tools/grumphp.yml"
        }
    },
    "scripts": {
        "dev-tools": "dev-tools",
        "dev-tools:fix": "@dev-tools --fix"
    }
}
